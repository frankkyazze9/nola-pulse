# Dark Horse — internal political research tool for Last Word Strategies.
# Copy to .env and fill in local-development values. Production secrets live
# in Google Secret Manager and are injected by Cloud Build at deploy time.

# --- Database ---
# Local Postgres (with pgvector extension installed).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/darkhorse"

# --- Anthropic Claude ---
# Get a key from console.anthropic.com. All LLM calls in Dark Horse go
# through lib/claude/spend.ts which logs every call to ApiSpendLog.
ANTHROPIC_API_KEY="sk-ant-..."

# --- Cron / background job authentication ---
# Shared secret for Cloud Scheduler → /api/jobs/* calls.
CRON_SECRET="change-me-in-prod"

# --- Google Cloud Platform ---
# Required because we use GCS (documents), Document AI (OCR), Cloud Run Jobs (scrapers).
# In production the Cloud Run service account has these permissions;
# locally, use `gcloud auth application-default login`.
GCP_PROJECT_ID="nola-ai-innovation"

# GCS bucket for raw scrape data + processed documents.
GCS_BUCKET="dark-horse-docs"

# Google Document AI processor ID for OCR. Create via `gcloud documentai processors create`.
DOCUMENT_AI_PROCESSOR_ID="projects/<project>/locations/us/processors/<id>"

# --- Self-hosted embeddings ---
# Internal URL of the `dark-horse-embed` Cloud Run service running BGE-small-en-v1.5.
# Not a third-party API — zero external cost, just Cloud Run compute.
EMBEDDING_SERVICE_URL="https://dark-horse-embed-<hash>-uc.a.run.app"
