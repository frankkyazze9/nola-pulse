# Dark Horse — internal political research tool.
# Copy to .env and fill in local-development values. Production secrets live
# in Google Secret Manager and are injected by Cloud Build at deploy time.

# --- Database ---
# Local Postgres (with pgvector extension installed).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/darkhorse"

# --- Anthropic Claude ---
# Get a key from console.anthropic.com. All LLM calls in Dark Horse go
# through lib/claude/spend.ts which logs every call to ApiSpendLog.
ANTHROPIC_API_KEY="sk-ant-..."

# --- Cron / background job authentication ---
# Shared secret for Cloud Scheduler → /api/jobs/* calls.
CRON_SECRET="change-me-in-prod"

# --- Google Cloud Platform ---
# Required because we use GCS (documents), Document AI (OCR), Cloud Run Jobs (scrapers).
# In production the Cloud Run service account has these permissions;
# locally, use `gcloud auth application-default login`.
GCP_PROJECT_ID="nola-ai-innovation"

# GCS bucket for raw scrape data + processed documents.
GCS_BUCKET="dark-horse-docs"

# Google Document AI processor ID for OCR. Created via `gcloud documentai processors create`.
# Production value: projects/845570509325/locations/us/processors/5af64dddbe7314c0
DOCUMENT_AI_PROCESSOR_ID="projects/845570509325/locations/us/processors/5af64dddbe7314c0"

# --- Self-hosted embeddings ---
# Internal URL of the `dark-horse-embed` Cloud Run service running BGE-small-en-v1.5.
# Not a third-party API — zero external cost, just Cloud Run compute.
EMBEDDING_SERVICE_URL="https://dark-horse-embed-<hash>-uc.a.run.app"

# --- Twitter/X (legacy — migrating to SociaVault in Phase 5) ---
# Direct Twitter API credentials. Stored in Secret Manager for production.
# These will be replaced by SOCIAVAULT_API_KEY once the SociaVault integration lands.
TWITTER_API_KEY=""
TWITTER_API_SECRET=""
TWITTER_ACCESS_TOKEN=""
TWITTER_ACCESS_SECRET=""

# --- SociaVault (Phase 5+) ---
# Unified social media API covering Twitter/X, Instagram, TikTok, Facebook, etc.
# Not needed until Phase 5 is implemented. See docs/ROADMAP.md.
# SOCIAVAULT_API_KEY=""

# --- Facebook Ad Library (required for scraper-fb-ad-library) ---
# User access token with `ads_read` scope from a developer app that has been
# identity-verified by Meta. Create at https://developers.facebook.com/apps/ →
# Ad Library API. Tokens expire; refresh via long-lived token flow.
# Docs: https://www.facebook.com/ads/library/api/
FACEBOOK_ACCESS_TOKEN=""

# --- CourtListener (optional, for scraper-courtlistener) ---
# Free account at https://www.courtlistener.com/help/api/. With a token the
# rate limit jumps from 5,000 to 50,000 req/day. Leave blank to fall back to
# anonymous (lower-rate) access.
COURTLISTENER_API_KEY=""
